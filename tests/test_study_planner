# S1.1 Add Study Task
# ==========================================
@given("I enter task name, type, and deadline", target_fixture="task_form_data")
def enter_task_details(app):
    with app.app_context():

        task_type = db.session.scalar(sa.select(TaskType))
        if not task_type:
            task_type = TaskType(title="Study", emoji="📚", color="#FFFFFF")
            db.session.add(task_type)
            db.session.commit()
        tt_id = str(task_type.id)


    return {
        "title": "Test Plan",
        "deadline": "2026-05-01",
        "task_titles[]": ["Math"],
        "task_hours[]": ["3.0"],
        "task_types[]": [tt_id]
    }


@when("I save the task")
def save_task(client, task_form_data):
    client.post("/plan/create", data=task_form_data, follow_redirects=True)


@then("it appears in my task list")
def task_appears(app, student_user):
    with app.app_context():
        user = db.session.merge(student_user)
        plan = db.session.scalar(sa.select(StudyPlan).where(StudyPlan.student_id == user.id))
        assert plan is not None
        assert plan.title == "Test Plan"
        assert len(plan.tasks) > 0
        assert plan.tasks[0].title == "Math"


