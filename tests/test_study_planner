# ==========================================
@given("task exists")
def task_exists(client, app):

    with app.app_context():
        task_type = db.session.scalar(sa.select(TaskType))
        if not task_type:
            task_type = TaskType(title="Study", emoji="📚", color="#FFFFFF")
            db.session.add(task_type)
            db.session.commit()
        tt_id = str(task_type.id)

    client.post("/plan/create", data={
        "title": "Test Plan",
        "deadline": "2026-05-01",
        "task_titles[]": ["Math"],
        "task_hours[]": ["3.0"],
        "task_types[]": [tt_id]
    }, follow_redirects=True)


@when("I edit or delete the task")
def edit_or_delete_task(client, app, student_user):
    with app.app_context():
        user = db.session.merge(student_user)
        task = db.session.scalar(sa.select(StudyTask).join(StudyPlan).where(StudyPlan.student_id == user.id))
        task_id = task.id
        task_type = db.session.scalar(sa.select(TaskType))
        tt_id = task_type.id if task_type else 1


    response = client.post(f"/task/{task_id}/edit", data={
        "title": "Updated",
        "estimated_hours": "4.0",
        "task_type": str(tt_id)
    }, follow_redirects=True)
    assert response.status_code == 200


@then("my task list stays accurate")
def task_list_accurate(app, student_user):
    with app.app_context():
        db.session.expire_all()
        user = db.session.merge(student_user)
        task = db.session.scalar(sa.select(StudyTask).join(StudyPlan).where(StudyPlan.student_id == user.id))
        assert task is not None
        assert task.title == "Updated"
        assert task.estimated_hours == 4.0


